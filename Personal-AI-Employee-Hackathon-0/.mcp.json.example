{
  "mcpServers": {
    "odoo_mcp": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/mnt/e/M.Y/GIAIC-Hackathons/Personal-AI-Employee-Hackathon-0/mcp_servers/odoo/server.py"
      ],
      "env": {
        "ODOO_URL": "http://localhost:8069",
        "ODOO_DB": "<your-odoo-db>",
        "ODOO_USER": "<your-odoo-user>",
        "ODOO_PASSWORD": "<your-odoo-password>",
        "VAULT_PATH": "./vault"
      }
    },
    "facebook_mcp": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/mnt/e/M.Y/GIAIC-Hackathons/Personal-AI-Employee-Hackathon-0/mcp_servers/facebook/server.py"
      ],
      "env": {
        "FACEBOOK_PAGE_ID": "<your-facebook-page-id>",
        "FACEBOOK_PAGE_ACCESS_TOKEN": "<your-facebook-page-access-token>",
        "INSTAGRAM_BUSINESS_ACCOUNT_ID": "",
        "VAULT_PATH": "./vault"
      }
    },
    "twitter_mcp": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/mnt/e/M.Y/GIAIC-Hackathons/Personal-AI-Employee-Hackathon-0/mcp_servers/twitter/server.py"
      ],
      "env": {
        "TWITTER_API_KEY": "<your-twitter-api-key>",
        "TWITTER_API_SECRET": "<your-twitter-api-secret>",
        "TWITTER_ACCESS_TOKEN": "<your-twitter-access-token>",
        "TWITTER_ACCESS_TOKEN_SECRET": "<your-twitter-access-token-secret>",
        "VAULT_PATH": "./vault"
      }
    }
  }
}