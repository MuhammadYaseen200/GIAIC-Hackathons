vault/Logs/*.jsonl
vault/Logs/*_state.json
vault/Logs/*.lock
vault/Untitled.base

# Vault HITL runtime data — demo artifacts with real decision metadata
vault/Approved/*.md
vault/Rejected/*.md
vault/Pending_Approval/*.md
vault/Done/*.md

# WhatsApp bridge databases — session keys and message history
store/messages.db
store/whatsapp.db
store/*.db

