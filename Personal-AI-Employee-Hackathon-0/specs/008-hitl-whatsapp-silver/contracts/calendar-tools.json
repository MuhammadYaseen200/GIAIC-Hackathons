{
  "server": "calendar_mcp",
  "version": "1.0.0",
  "transport": "stdio",
  "framework": "FastMCP + Pydantic v2",
  "entry_point": "mcp_servers/calendar/server.py",
  "env_required": ["CALENDAR_CREDENTIALS_PATH", "CALENDAR_TOKEN_PATH"],
  "scopes": ["https://www.googleapis.com/auth/calendar.readonly"],
  "tools": [
    {
      "name": "list_events",
      "description": "List Google Calendar events in a time window. Used by orchestrator to provide scheduling context for email drafting.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "time_min": {
            "type": "string",
            "format": "date-time",
            "description": "Start of time window (ISO 8601 with timezone, e.g., '2026-03-02T00:00:00Z')"
          },
          "time_max": {
            "type": "string",
            "format": "date-time",
            "description": "End of time window (ISO 8601 with timezone). Default: time_min + 7 days"
          },
          "max_results": {
            "type": "integer",
            "minimum": 1,
            "maximum": 250,
            "default": 10,
            "description": "Maximum number of events to return (1-250)"
          }
        },
        "required": ["time_min"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "event_id": { "type": "string", "description": "Google Calendar event ID" },
                "summary": { "type": "string", "description": "Event title" },
                "start": { "type": "string", "format": "date-time", "description": "ISO 8601 start time" },
                "end": { "type": "string", "format": "date-time", "description": "ISO 8601 end time" },
                "attendees": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "List of attendee email addresses"
                },
                "location": { "type": ["string", "null"], "description": "Event location if set" }
              },
              "required": ["event_id", "summary", "start", "end", "attendees"]
            }
          },
          "calendar_id": { "type": "string", "description": "Calendar ID queried (usually 'primary')" },
          "fetched_at": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of query" }
        },
        "required": ["events", "calendar_id", "fetched_at"]
      },
      "errorCodes": ["auth_required", "rate_limited", "internal_error"],
      "notes": [
        "Requires calendar_token.json generated by scripts/calendar_auth.py (HT-011)",
        "Uses same credentials.json as Gmail MCP (same Google Cloud project)",
        "time_max defaults to time_min + 7 days if not provided",
        "Returns empty events list (not error) if no events in window",
        "Read-only — cannot create or modify events"
      ]
    },
    {
      "name": "check_availability",
      "description": "Check if a specific time slot is available (no conflicting events). Returns available=true if slot is free.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "time_slot_start": {
            "type": "string",
            "format": "date-time",
            "description": "Start of slot to check (ISO 8601)"
          },
          "time_slot_end": {
            "type": "string",
            "format": "date-time",
            "description": "End of slot to check (ISO 8601)"
          }
        },
        "required": ["time_slot_start", "time_slot_end"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "is_available": {
            "type": "boolean",
            "description": "True if no events overlap the requested slot"
          },
          "conflicting_events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "event_id": { "type": "string" },
                "summary": { "type": "string" },
                "start": { "type": "string", "format": "date-time" },
                "end": { "type": "string", "format": "date-time" },
                "attendees": { "type": "array", "items": { "type": "string" } },
                "location": { "type": ["string", "null"] }
              },
              "required": ["event_id", "summary", "start", "end", "attendees"]
            },
            "description": "Events that overlap the requested slot (empty if available)"
          },
          "suggested_alternatives": {
            "type": ["array", "null"],
            "items": { "type": "string" },
            "description": "Alternative free slot suggestions (future feature, null in Phase 5)"
          }
        },
        "required": ["is_available", "conflicting_events"]
      },
      "errorCodes": ["auth_required", "rate_limited", "internal_error"],
      "notes": [
        "Internally calls list_events with the slot as time window",
        "Event overlap check: event.start < slot_end AND event.end > slot_start",
        "Returns is_available=true if conflicting_events is empty"
      ]
    },
    {
      "name": "health_check",
      "description": "Check Google Calendar API connectivity and OAuth token validity.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["healthy", "degraded", "down"],
            "description": "Calendar API health status"
          },
          "calendar_id": {
            "type": "string",
            "description": "Primary calendar ID (usually Google account email)"
          },
          "email": {
            "type": "string",
            "description": "Google account email address associated with token"
          }
        },
        "required": ["status", "calendar_id", "email"]
      },
      "errorCodes": ["auth_required", "internal_error"],
      "notes": [
        "health_check must respond within 3 seconds",
        "Returns auth_required if calendar_token.json is missing or expired",
        "Token refresh is automatic if refresh_token present in calendar_token.json"
      ]
    }
  ],
  "errorFormat": {
    "description": "All errors returned as CallToolResult(isError=True) with JSON content",
    "schema": {
      "type": "object",
      "properties": {
        "error": {
          "type": "string",
          "enum": ["auth_required", "not_found", "rate_limited", "permission_denied", "parse_error", "send_failed", "mcp_unavailable", "internal_error"]
        },
        "message": { "type": "string" },
        "details": { "type": ["object", "null"] }
      },
      "required": ["error", "message"]
    }
  },
  "contractTests": [
    "tests/contract/test_calendar_mcp_contracts.py",
    "Verify list_events returns empty array (not error) for window with no events",
    "Verify check_availability correctly identifies conflicts",
    "Verify health_check returns auth_required when token missing",
    "Verify all output matches outputSchema exactly",
    "Verify isError=True flag set on all error responses"
  ]
}
